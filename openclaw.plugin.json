{
  "id": "imap",
  "channels": [
    "imap"
  ],
  "channelEnvVars": {
    "imap": []
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "channelConfigs": {
    "imap": {
      "label": "Email",
      "description": "IMAP/SMTP mailbox — IDLE push, reply threading, pass-friendly secrets.",
      "schema": {
        "type": "object",
        "properties": {
          "dryRun": {
            "default": false,
            "description": "Receive IMAP only; skip SMTP transport and reply dispatch",
            "type": "boolean"
          },
          "security": {
            "type": "object",
            "description": "Authentication gate + sanitization limits. All defaults fail closed; relax only with explicit intent.",
            "properties": {
              "requireAuthenticationResults": {
                "default": true,
                "description": "Drop if the receiving MTA did not add an Authentication-Results: header (DKIM/SPF/DMARC milter not run).",
                "type": "boolean"
              },
              "dropOnDkimFail": {
                "default": true,
                "description": "Drop on DKIM=fail. Disable only if you expect legitimate traffic through forwarders that break DKIM signatures.",
                "type": "boolean"
              },
              "dropOnSpfFail": {
                "default": true,
                "description": "Drop on SPF=fail (envelope sender not authorized).",
                "type": "boolean"
              },
              "dropOnDmarcFail": {
                "default": true,
                "description": "Drop on DMARC=fail. Spoofed sender — no legitimate reason to route to the agent.",
                "type": "boolean"
              },
              "maxBodyChars": {
                "default": 8000,
                "description": "Hard cap on body characters sent to the agent. Longer bodies are truncated with a marker.",
                "type": "integer",
                "minimum": 1024,
                "maximum": 1048576
              },
              "allowlist": {
                "description": "Opt-in sender allowlist. When empty/absent, all envelope-from addresses pass the allowlist check; when non-empty, any envelope-from not matching a rule is dropped.",
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "from": {
                      "description": "Exact envelope-from address (case-insensitive).",
                      "type": "string"
                    },
                    "domain": {
                      "description": "Domain suffix (case-insensitive). Matches envelope-from ending with @<domain> or .<domain>.",
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "rateLimit": {
                "description": "In-memory rate limits. Reset on restart. Acts as DoS throttle, not audit log.",
                "type": "object",
                "properties": {
                  "disabled": {
                    "default": false,
                    "description": "Disable all rate limiting. Use only for tests or dev.",
                    "type": "boolean"
                  },
                  "perAccountPerMinute": {
                    "default": 10,
                    "description": "Max dispatches per account per minute.",
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 10000
                  },
                  "perAccountPerHour": {
                    "default": 100,
                    "description": "Max dispatches per account per hour.",
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100000
                  },
                  "perSenderPerHour": {
                    "default": 5,
                    "description": "Max dispatches per individual envelope-from per hour.",
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 10000
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          },
          "secrets": {
            "type": "object",
            "properties": {
              "backend": {
                "default": "pass",
                "description": "Secret resolver backend",
                "type": "string",
                "enum": [
                  "pass",
                  "env"
                ]
              },
              "binary": {
                "description": "Override path to pass binary",
                "type": "string"
              },
              "timeoutMs": {
                "description": "Secret resolve timeout in ms",
                "type": "integer",
                "minimum": 100,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "backend"
            ],
            "additionalProperties": false
          },
          "accounts": {
            "description": "IMAP/SMTP accounts keyed by account id",
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "object",
              "properties": {
                "enabled": {
                  "default": true,
                  "description": "Run this account",
                  "type": "boolean"
                },
                "imap": {
                  "type": "object",
                  "properties": {
                    "host": {
                      "type": "string",
                      "description": "IMAP server hostname"
                    },
                    "port": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535,
                      "description": "IMAP server port (993 for TLS)"
                    },
                    "secure": {
                      "description": "Use implicit TLS",
                      "type": "boolean"
                    },
                    "user": {
                      "type": "string",
                      "description": "IMAP username"
                    },
                    "password": {
                      "type": "string",
                      "description": "IMAP password or !secret reference"
                    },
                    "mailbox": {
                      "default": "INBOX",
                      "description": "Mailbox to watch",
                      "type": "string"
                    }
                  },
                  "required": [
                    "host",
                    "port",
                    "user",
                    "password",
                    "mailbox"
                  ],
                  "additionalProperties": false
                },
                "smtp": {
                  "type": "object",
                  "properties": {
                    "host": {
                      "type": "string",
                      "description": "SMTP server hostname"
                    },
                    "port": {
                      "type": "integer",
                      "minimum": 1,
                      "maximum": 65535,
                      "description": "SMTP server port (587 STARTTLS, 465 implicit TLS)"
                    },
                    "secure": {
                      "description": "Use implicit TLS",
                      "type": "boolean"
                    },
                    "user": {
                      "type": "string",
                      "description": "SMTP username"
                    },
                    "password": {
                      "type": "string",
                      "description": "SMTP password or !secret reference"
                    },
                    "from": {
                      "type": "string",
                      "description": "Default From header (e.g. Name <user@example.com>)"
                    }
                  },
                  "required": [
                    "host",
                    "port",
                    "user",
                    "password",
                    "from"
                  ],
                  "additionalProperties": false
                },
                "sentMailbox": {
                  "description": "Override for the Sent-folder IMAP path. Empty/absent = auto-detect via SPECIAL-USE \\Sent.",
                  "type": "string"
                }
              },
              "required": [
                "enabled",
                "imap",
                "smtp"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "dryRun"
        ],
        "additionalProperties": false
      },
      "uiHints": {
        "dryRun": {
          "label": "Dry run",
          "help": "Receive IMAP only; skip SMTP transport and reply dispatch."
        },
        "secrets.backend": {
          "label": "Secrets backend",
          "help": "Where `!secret …` references are resolved."
        },
        "secrets.binary": {
          "label": "Pass binary",
          "help": "Path override for the pass CLI.",
          "advanced": true
        },
        "secrets.timeoutMs": {
          "label": "Resolve timeout (ms)",
          "advanced": true
        },
        "accounts.*.enabled": {
          "label": "Enabled"
        },
        "accounts.*.imap.host": {
          "label": "IMAP host",
          "placeholder": "mail.example.com"
        },
        "accounts.*.imap.port": {
          "label": "IMAP port",
          "placeholder": "993"
        },
        "accounts.*.imap.secure": {
          "label": "IMAP TLS"
        },
        "accounts.*.imap.user": {
          "label": "IMAP user"
        },
        "accounts.*.imap.password": {
          "label": "IMAP password",
          "sensitive": true
        },
        "accounts.*.imap.mailbox": {
          "label": "Mailbox"
        },
        "accounts.*.smtp.host": {
          "label": "SMTP host",
          "placeholder": "mail.example.com"
        },
        "accounts.*.smtp.port": {
          "label": "SMTP port",
          "placeholder": "587"
        },
        "accounts.*.smtp.secure": {
          "label": "SMTP TLS"
        },
        "accounts.*.smtp.user": {
          "label": "SMTP user"
        },
        "accounts.*.smtp.password": {
          "label": "SMTP password",
          "sensitive": true
        },
        "accounts.*.smtp.from": {
          "label": "From header",
          "placeholder": "Name <user@example.com>"
        },
        "accounts.*.sentMailbox": {
          "label": "Sent folder override",
          "help": "Leave empty to auto-detect via SPECIAL-USE \\Sent. Only set if the server does not advertise SPECIAL-USE and the folder is not named Sent/Gesendet/INBOX.Sent.",
          "placeholder": "Sent",
          "advanced": true
        },
        "security": {
          "label": "Security"
        },
        "security.requireAuthenticationResults": {
          "label": "Require Authentication-Results header",
          "help": "Drop mail that arrives without a receiver-stamped Authentication-Results header. Leave ON unless your MTA genuinely does not run a DKIM/SPF/DMARC milter."
        },
        "security.dropOnDkimFail": {
          "label": "Drop on DKIM fail",
          "help": "Disable only to accept mail from forwarders or mailing lists that routinely break DKIM. Pair with sender allowlist."
        },
        "security.dropOnSpfFail": {
          "label": "Drop on SPF fail",
          "help": "Envelope sender not authorized to send for its domain."
        },
        "security.dropOnDmarcFail": {
          "label": "Drop on DMARC fail",
          "help": "DMARC fail means the sender's own published policy says the mail is a spoof. No legitimate reason to route it to the agent."
        },
        "security.maxBodyChars": {
          "label": "Max body chars",
          "help": "Hard cap on body length sent to the agent. Longer bodies are truncated.",
          "advanced": true
        },
        "security.allowlist": {
          "label": "Sender allowlist",
          "help": "Opt-in. When empty, every envelope-from passes. When non-empty, anything not matching an entry is dropped before it reaches the agent.",
          "advanced": true
        },
        "security.rateLimit": {
          "label": "Rate limit"
        },
        "security.rateLimit.disabled": {
          "label": "Disable rate limiting",
          "help": "Use only for tests. Leave OFF in production.",
          "advanced": true
        },
        "security.rateLimit.perAccountPerMinute": {
          "label": "Per-account / minute",
          "advanced": true
        },
        "security.rateLimit.perAccountPerHour": {
          "label": "Per-account / hour",
          "advanced": true
        },
        "security.rateLimit.perSenderPerHour": {
          "label": "Per-sender / hour",
          "help": "Caps how many replies a single envelope-from can trigger per hour. Stops single-sender floods.",
          "advanced": true
        }
      }
    }
  }
}
